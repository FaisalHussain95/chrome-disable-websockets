{
	"manifest_version": 3,

	"name": "Disable WebSockets",
	"description": "This extension disables WebSockets",
	"version": "1.5",
	"author": "arthepsy",

	"permissions": ["storage"],
	"action": {
		"default_popup": "popup.html",
		"default_title": "WebSocket Blocker"
	},
	"content_scripts": [
		{
			"matches": ["http://*/*", "https://*/*"],
			"js": ["content.js"],
			"run_at": "document_start"
		},
		{
			"matches": ["http://*/*", "https://*/*"],
			"js": ["script.js"],
			"run_at": "document_start",
			"world": "MAIN"
		}
	]
}
