{
	"manifest_version": 3,

	"name": "Disable WebSockets",
	"description": "This extension disables WebSockets",
	"version": "1.1",
	"author": "arthepsy",

	"web_accessible_resources": [{
		"resources": ["script.js"],
		"matches": ["http://*/*", "https://*/*"]
	}],
	"content_scripts": [{
		"matches": ["http://*/*", "https://*/*"],
		"js": ["content.js"],
		"run_at": "document_start"
	}]
}
