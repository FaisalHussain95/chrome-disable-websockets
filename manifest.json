{
	"manifest_version": 3,

	"name": "Disable WebSockets",
	"description": "This extension disables WebSockets",
	"version": "1.3",
	"author": "arthepsy",

	"permissions": ["storage"],
	"action": {
		"default_popup": "popup.html",
		"default_title": "WebSocket Blocker"
	},
	"web_accessible_resources": [{
		"resources": ["script.js"],
		"matches": ["http://*/*", "https://*/*"]
	}],
	"content_scripts": [{
		"matches": ["http://*/*", "https://*/*"],
		"js": ["content.js"],
		"run_at": "document_start"
	}]
}
